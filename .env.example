# Optional AI conversion
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-2025-04-14
CF_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Optional notifications
DISCORD_WEBHOOK_URL=
DISCORD_LINK_WEBHOOK_URL=
RESEND_API_KEY=
NOTIFICATION_EMAIL=

# Clerk auth foundation (Phase 1)
# Public key used by frontend Clerk JS
CLERK_PUBLISHABLE_KEY=

# Clerk session token verification on the worker
# Example: https://your-instance.clerk.accounts.dev
CLERK_JWT_ISSUER=

# Optional: expected audience claim in Clerk JWTs
CLERK_JWT_AUDIENCE=

# Optional: custom auth route hints for frontend redirects
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up

# Optional for future server-side Clerk operations (not required in Phase 1)
CLERK_SECRET_KEY=
